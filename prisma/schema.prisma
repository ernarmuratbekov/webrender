// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

// Эту схему я сделал, ну типа, чтобы приблизиться к практике.
// В СКУ есть драфт ПЦО по воде. они купили за 25 лямов ArcGis Enterprise
// Там можно сделать таблицу, есть свой PostGis и кодить Drag and Drop.
// но там возникли траблы и в итоге оно не работает.
// Вы создаете прототип на базе MailDoby, Некста и Неста с постгересочкой.
// предварительно я взял информацию от директора ПЦО о том какие данные нужно
// фиксировать по водоемам СКО и это прописал в данной схеме Prisma.
// тут все показатели и физико-химические и биоиндокационные.
// Через Админку (отдельно пишете проект на Нексте) - можно добавлять юзеров
// сами водоемы, а также их показатели.

model User {
  id        String @id @default(uuid())
  login     String @unique
  email     String @unique
  password  String
  avatarUrl String? @map("avatar_url")
  role      Role @default(CLIENT)

  @@map("users")
}

model WaterBody {
  id              String  @id @default(uuid())
  name            String  // Наименование водоема
  district        String? // Район
  locationDesc    String? @map("location_desc") // Расположение

  latitude   Float?
  longitude  Float?
  boundaries Json?

  cadastralNumber String? @map("cadastral_number") // Кадастровый номер

  passport     WaterBodyPassport?
  measurements BioindicationRecord[]

  @@map("water_bodies")
}

model WaterBodyPassport {
  id          String @id @default(uuid())
  waterBodyId String @unique @map("water_body_id")
  waterBody   WaterBody @relation(fields: [waterBodyId], references: [id], onDelete: Cascade)

  // Морфометрические характеристики
  area            Float? @map("area_ha") // Площадь, га
  overgrowthArea  Float? @map("overgrowth_area_ha") // Площадь зарастания, га
  altitude        Float? @map("altitude_m") // Высота над уровнем моря, м
  length          Float? @map("length_km") // Длина, км
  maxWidth        Float? @map("max_width_km") // Наибольшая ширина, км
  coastlineLength Float? @map("coastline_length_km") // Длина береговой линии, км
  coastlineDev    Float? @map("coastline_development") // Развитие береговой линии
  catchmentArea   Float? @map("catchment_area_sq_km") // Водосборная площадь, кв. км
  currentDepth    Float? @map("current_depth_m") // Глубина, м
  maxDepth        Float? @map("max_depth_m") // Максимальная глубина, м
  avgDepth        Float? @map("avg_depth_m") // Средняя глубина, м
  volume          Float? @map("volume_mln_m3") // Объем водной массы, млн. м3

  // Основные гидрологические и хозяйственные характеристики
  fisheryType          String? @map("fishery_type") // Вид рыбного хозяйства
  fishProductivity     Float? @map("fish_productivity") // Рыбопродуктивность водоема, кг/га
  economicDesc         String? @db.Text @map("economic_desc") // Хозяйственная характеристика
  waterProtectionZone  String? @map("water_protection_zone") // Водоохранные зоны
  waterProtectionStrip String? @map("water_protection_strip") // Водоохранные полосы

  // Видовой состав фауны (общий/исторический)
  ichthyofauna String? @db.Text // Ихтиофауна
  mammals      String? @db.Text // Млекопитающие
  invertebrates String? @db.Text // Беспозвоночные водные животные

  @@map("water_body_passports")
}

// --- Экологические замеры (Динамичные показатели) ---
model BioindicationRecord {
  id          String @id @default(uuid())
  waterBodyId String @map("water_body_id")
  waterBody   WaterBody @relation(fields: [waterBodyId], references: [id], onDelete: Cascade)

  recordDate DateTime @default(now()) @map("record_date") // Дата забора

  // Химические показатели
  ph               Float?
  turbidity        Float?
  dissolvedGases   String? @map("dissolved_gases") // Растворенные газы, мг/дм3
  biogenicCompounds String? @map("biogenic_compounds") // Биогенные соединения, мг/дм3
  permanganateOxid Float? @map("permanganate_oxid") // Перманганатная окисляемость, мг/дм3

  // Ионный состав и минерализация воды
  mineralization Float? // Минерализация, мг/дм3
  salinity       Float? // Соленость
  hardness       Float? // Жесткость, мг-экв./дм3
  calcium        Float? // Кальций, мг/дм3
  magnesium      Float? // Магний, мг/дм3
  chlorides      Float? // Хлориды, мг/дм3
  sulfates       Float? // Сульфаты, мг/дм3
  hydrocarbons   Float? // Гидрокарбонаты, мг/дм3
  potassiumSodium Float? @map("potassium_sodium") // Калий + Натрий, мг/дм3

  // Характер и степень зарастания
  overgrowthPercent Float? @map("overgrowth_percent") // Процент зарастания, %
  overgrowthDegree  String? @map("overgrowth_degree") // Степень зарастания

  // Биология и планктон
  phytoplanktonDev String? @map("phytoplankton_dev") // Степень развития фитопланктона (цветение воды)
  zooplanktonTaxa  String? @db.Text @map("zooplankton_taxa") // Таксономический состав зоопланктона
  zooplanktonGroups String? @db.Text @map("zooplankton_groups") // Основные группы зоопланктона
  zoobenthosTaxa   String? @db.Text @map("zoobenthos_taxa") // Таксономический состав зообентоса
  zoobenthosGroups String? @db.Text @map("zoobenthos_groups") // Основные группы зообентоса
  trophicStatus    String? @map("trophic_status") // Оценка трофности водоема по биом

  @@map("bioindication_records")
}